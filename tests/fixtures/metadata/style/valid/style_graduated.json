{
  "version": 8,
  "name": "Population Density",
  "sources": {
    "data": {
      "type": "vector",
      "url": "../parcels.pmtiles"
    }
  },
  "layers": [
    {
      "id": "parcels-graduated",
      "type": "fill",
      "source": "data",
      "source-layer": "parcels",
      "paint": {
        "fill-color": [
          "interpolate", ["linear"], ["get", "population"],
